<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_source_form" model="ir.ui.view">
        <field name="name">dataset.source.form</field>
        <field name="model">dataset.source</field>
        <field name="arch" type="xml">
            <form string="Source">
                <sheet>
                    <group>
                        <field name="code"/>
                        <field name="name"/>
                        <field name="url"/>
                    </group>
                    <group>
                        <field name="description"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_source_list" model="ir.ui.view">
        <field name="name">dataset.source.list</field>
        <field name="model">dataset.source</field>
        <field name="arch" type="xml">
            <list string="Sources">
                <field name="code"/>
                <field name="name"/>
                <field name="url"/>
            </list>
        </field>
    </record>

    <record id="action_source" model="ir.actions.act_window">
        <field name="name">Sources</field>
        <field name="res_model">dataset.source</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
