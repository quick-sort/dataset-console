<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_data_chunk_form" model="ir.ui.view">
        <field name="name">dataset.data_chunk.form</field>
        <field name="model">dataset.data_chunk</field>
        <field name="arch" type="xml">
            <form string="Data Chunk">
                <sheet>
                    <group>
                        <field name="key"/>
                        <field name="dataset_id"/>
                        <field name="state"/>
                    </group>
                    <group>
                        <field name="size"/>
                        <label for="metadata"/>
                        <div class="o_row">
                            <field name="metadata"/>
                            <button name="action_edit_metadata" type="object"
                                    string="Edit" class="btn-link"
                                    icon="fa-pencil"/>
                        </div>
                    </group>
                    <group>
                        <field name="raw_data" filename="raw_data_filename"/>
                        <field name="raw_data_filename" invisible="1"/>
                    </group>
                    <group>
                        <field name="description"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_data_chunk_list" model="ir.ui.view">
        <field name="name">dataset.data_chunk.list</field>
        <field name="model">dataset.data_chunk</field>
        <field name="arch" type="xml">
            <list string="Data Chunks">
                <field name="dataset_id"/>
                <field name="key"/>
                <field name="size"/>
                <field name="state" widget="badge"
                       decoration-danger="state == 'missing'"
                       decoration-warning="state == 'exists'"
                       decoration-success="state == 'checked'"/>
                <field name="raw_data" filename="raw_data_filename"/>
                <field name="raw_data_filename" column_invisible="1"/>
            </list>
        </field>
    </record>

    <record id="view_data_chunk_search" model="ir.ui.view">
        <field name="name">dataset.data_chunk.search</field>
        <field name="model">dataset.data_chunk</field>
        <field name="arch" type="xml">
            <search string="Data Chunks">
                <field name="key"/>
                <field name="dataset_id"/>
                <filter string="Missing" name="state_missing" domain="[('state', '=', 'missing')]"/>
                <filter string="Exists" name="state_exists" domain="[('state', '=', 'exists')]"/>
                <filter string="Checked" name="state_checked" domain="[('state', '=', 'checked')]"/>
                <group>
                    <filter string="Dataset" name="group_dataset" domain="[]" context="{'group_by': 'dataset_id'}"/>
                    <filter string="State" name="group_state" domain="[]" context="{'group_by': 'state'}"/>
                </group>
                <searchpanel>
                    <field name="dataset_id" string="Datasets" select="multi" enable_counters="1" icon="fa-database"/>
                </searchpanel>
            </search>
        </field>
    </record>

    <record id="action_data_chunk" model="ir.actions.act_window">
        <field name="name">Data Chunks</field>
        <field name="res_model">dataset.data_chunk</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_data_chunk_search"/>
    </record>
</odoo>
