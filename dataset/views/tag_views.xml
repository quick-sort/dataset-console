<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_tag_form" model="ir.ui.view">
        <field name="name">dataset.tag.form</field>
        <field name="model">dataset.tag</field>
        <field name="arch" type="xml">
            <form string="Tag">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="color" widget="color_picker"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_tag_list" model="ir.ui.view">
        <field name="name">dataset.tag.list</field>
        <field name="model">dataset.tag</field>
        <field name="arch" type="xml">
            <list string="Tags">
                <field name="name"/>
                <field name="color" widget="color_picker"/>
            </list>
        </field>
    </record>

    <record id="action_tag" model="ir.actions.act_window">
        <field name="name">Tags</field>
        <field name="res_model">dataset.tag</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>