<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_dataset_form" model="ir.ui.view">
        <field name="name">dataset.form</field>
        <field name="model">dataset</field>
        <field name="arch" type="xml">
            <form string="Dataset">
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_chunks" type="object"
                                class="oe_stat_button" icon="fa-cubes">
                            <field name="total_chunks" widget="statinfo" string="Chunks"/>
                        </button>
                    </div>
                    <group>
                        <group>
                            <field name="code"/>
                            <field name="source_id"/>
                            <field name="package_id"/>
                            <field name="chunk_type"/>
                        </group>
                        <group>
                            <field name="name"/>
                            <field name="manifest_id"/>
                            <field name="tag_ids" widget="many2many_tags" options="{'color_field': 'color'}"/>
                            <field name="filter_domain" placeholder="[('split', '=', 'train')]"/>
                            <field name="fill_rate" widget="percentage"/>
                        </group>
                    </group>
                    <group>
                        <field name="key_fields" widget="json_editor"/>
                        <field name="description"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_dataset_list" model="ir.ui.view">
        <field name="name">dataset.list</field>
        <field name="model">dataset</field>
        <field name="arch" type="xml">
            <list string="Datasets">
                <field name="code"/>
                <field name="name"/>
                <field name="source_id"/>
                <field name="package_id"/>
                <field name="manifest_id" optional="hide"/>
                <field name="chunk_type"/>
                <field name="tag_ids" widget="many2many_tags" options="{'color_field': 'color'}"/>
                <field name="total_chunks"/>
                <field name="filtered_total_chunks" optional="hide"/>
                <field name="fill_rate" widget="percentage"/>
                <field name="filter_domain" optional="hide"/>
            </list>
        </field>
    </record>

    <record id="view_dataset_kanban" model="ir.ui.view">
        <field name="name">dataset.kanban</field>
        <field name="model">dataset</field>
        <field name="arch" type="xml">
            <kanban sample="1">
                <field name="package_id"/>
                <field name="manifest_id"/>
                <templates>
                    <t t-name="card">
                        <div class="mb-2">
                            <field name="name" class="fw-bolder fs-5"/>
                            <field name="code" class="text-muted d-block"/>
                        </div>
                        <div>
                            <i class="fa fa-database me-1" title="Source"/><field name="source_id"/>
                        </div>
                        <div t-if="record.package_id.raw_value">
                            <i class="fa fa-folder me-1" title="Package"/><field name="package_id"/>
                        </div>
                        <div t-if="record.manifest_id.raw_value" class="mt-2">
                            <div class="d-flex justify-content-between small text-muted">
                                <span>Fill rate</span>
                                <span><field name="fill_rate" widget="percentage"/></span>
                            </div>
                            <field name="fill_rate" widget="progressbar"
                                   options="{'editable': false}"/>
                        </div>
                        <footer class="pt-2">
                            <field name="chunk_type" widget="badge"/>
                            <field name="tag_ids" widget="many2many_tags" options="{'color_field': 'color'}"/>
                            <span class="ms-auto text-muted">
                                <field name="total_chunks"/> chunks
                            </span>
                        </footer>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="view_dataset_search" model="ir.ui.view">
        <field name="name">dataset.search</field>
        <field name="model">dataset</field>
        <field name="arch" type="xml">
            <search string="Datasets">
                <field name="name"/>
                <field name="code"/>
                <field name="tag_ids"/>
                <field name="source_id"/>
                <field name="package_id"/>
                <field name="manifest_id"/>
                <group>
                    <filter string="Source" name="group_source" domain="[]" context="{'group_by': 'source_id'}"/>
                    <filter string="Package" name="group_package" domain="[]" context="{'group_by': 'package_id'}"/>
                    <filter string="Manifest" name="group_manifest" domain="[]" context="{'group_by': 'manifest_id'}"/>
                    <filter string="Data Type" name="group_data_type" domain="[]" context="{'group_by': 'chunk_type'}"/>
                    <filter string="Tag" name="group_tag" domain="[]" context="{'group_by': 'tag_ids'}"/>
                </group>
                <searchpanel>
                    <field name="source_id" string="Sources" select="multi" enable_counters="1" icon="fa-database"/>
                    <field name="package_id" string="Packages" select="one" enable_counters="1" icon="fa-folder"/>
                </searchpanel>
            </search>
        </field>
    </record>

    <record id="action_dataset" model="ir.actions.act_window">
        <field name="name">Datasets</field>
        <field name="res_model">dataset</field>
        <field name="path">datasets</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="search_view_id" ref="view_dataset_search"/>
    </record>
</odoo>
