<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_package_form" model="ir.ui.view">
        <field name="name">dataset.package.form</field>
        <field name="model">dataset.package</field>
        <field name="arch" type="xml">
            <form string="Package">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="code"/>
                        <field name="parent_id"/>
                    </group>
                    <group>
                        <field name="description"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_package_list" model="ir.ui.view">
        <field name="name">dataset.package.list</field>
        <field name="model">dataset.package</field>
        <field name="arch" type="xml">
            <list string="Packages" edit="0" create="0" expand="1">
                <field name="name"/>
                <field name="code"/>
                <field name="parent_id"/>
            </list>
        </field>
    </record>

    <record id="action_package" model="ir.actions.act_window">
        <field name="name">Packages</field>
        <field name="res_model">dataset.package</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
