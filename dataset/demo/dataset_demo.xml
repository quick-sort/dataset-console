<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">

    <!-- Sources -->
    <record id="source_huggingface" model="dataset.source">
        <field name="name">Hugging Face</field>
        <field name="code">hf</field>
        <field name="url">https://huggingface.co/datasets</field>
        <field name="description">Datasets hosted on the Hugging Face Hub.</field>
    </record>

    <record id="source_kaggle" model="dataset.source">
        <field name="name">Kaggle</field>
        <field name="code">kaggle</field>
        <field name="url">https://www.kaggle.com/datasets</field>
        <field name="description">Datasets published on Kaggle competitions and community.</field>
    </record>

    <record id="source_internal" model="dataset.source">
        <field name="name">Internal</field>
        <field name="code">internal</field>
        <field name="description">In-house datasets curated by the data team.</field>
    </record>

    <!-- Packages (hierarchical) -->
    <record id="package_nlp" model="dataset.package">
        <field name="name">NLP</field>
        <field name="code">nlp</field>
        <field name="description">Natural Language Processing datasets.</field>
    </record>

    <record id="package_nlp_classification" model="dataset.package">
        <field name="name">Text Classification</field>
        <field name="code">classification</field>
        <field name="parent_id" ref="package_nlp"/>
    </record>

    <record id="package_nlp_qa" model="dataset.package">
        <field name="name">Question Answering</field>
        <field name="code">qa</field>
        <field name="parent_id" ref="package_nlp"/>
    </record>

    <record id="package_vision" model="dataset.package">
        <field name="name">Computer Vision</field>
        <field name="code">vision</field>
        <field name="description">Image and video datasets.</field>
    </record>

    <record id="package_vision_classification" model="dataset.package">
        <field name="name">Image Classification</field>
        <field name="code">classification</field>
        <field name="parent_id" ref="package_vision"/>
    </record>

    <record id="package_tabular" model="dataset.package">
        <field name="name">Tabular</field>
        <field name="code">tabular</field>
        <field name="description">Structured / tabular datasets.</field>
    </record>

    <!-- Manifests -->
    <record id="manifest_imdb_v1" model="dataset.manifest">
        <field name="name">imdb-v1</field>
        <field name="type">dataset</field>
        <field name="values" eval="[
            {'split': 'train', 'shard': '0001'},
            {'split': 'train', 'shard': '0002'},
            {'split': 'test',  'shard': '0001'},
            {'split': 'test',  'shard': '0002'},
        ]"/>
        <field name="description">Initial published manifest for the IMDB Reviews dataset (expects 4 chunks).</field>
    </record>

    <record id="manifest_squad_v2" model="dataset.manifest">
        <field name="name">squad-v2</field>
        <field name="type">dataset</field>
        <field name="values" eval="[
            {'split': 'train'},
            {'split': 'dev'},
        ]"/>
        <field name="description">Manifest for SQuAD v2 with unanswerable questions (expects 2 chunks).</field>
    </record>

    <!-- Datasets -->
    <record id="dataset_imdb" model="dataset">
        <field name="name">IMDB Reviews</field>
        <field name="code">imdb</field>
        <field name="source_id" ref="source_huggingface"/>
        <field name="package_id" ref="package_nlp_classification"/>
        <field name="manifest_id" ref="manifest_imdb_v1"/>
        <field name="chunk_type">parquet</field>
        <field name="key_fields" eval="['split', 'shard']"/>
        <field name="description">50k movie reviews labeled with sentiment (positive/negative).</field>
    </record>

    <record id="dataset_squad" model="dataset">
        <field name="name">SQuAD v2</field>
        <field name="code">squad_v2</field>
        <field name="source_id" ref="source_huggingface"/>
        <field name="package_id" ref="package_nlp_qa"/>
        <field name="manifest_id" ref="manifest_squad_v2"/>
        <field name="chunk_type">json</field>
        <field name="key_fields" eval="['split']"/>
        <field name="description">Stanford Question Answering Dataset, version 2 with unanswerable questions.</field>
    </record>

    <record id="dataset_cifar10" model="dataset">
        <field name="name">CIFAR-10</field>
        <field name="code">cifar10</field>
        <field name="source_id" ref="source_kaggle"/>
        <field name="package_id" ref="package_vision_classification"/>
        <field name="chunk_type">parquet</field>
        <field name="key_fields" eval="['split', 'shard']"/>
        <field name="description">60k 32x32 color images across 10 classes.</field>
    </record>

    <record id="dataset_titanic" model="dataset">
        <field name="name">Titanic Survival</field>
        <field name="code">titanic</field>
        <field name="source_id" ref="source_kaggle"/>
        <field name="package_id" ref="package_tabular"/>
        <field name="chunk_type">csv</field>
        <field name="description">Classic Titanic passenger survival dataset.</field>
    </record>

    <record id="dataset_internal_support" model="dataset">
        <field name="name">Support Ticket Triage</field>
        <field name="code">support_triage</field>
        <field name="source_id" ref="source_internal"/>
        <field name="package_id" ref="package_nlp_classification"/>
        <field name="chunk_type">jsonl</field>
        <field name="key_fields" eval="['lang', 'month']"/>
        <field name="description">Internal customer support tickets labeled by topic for triage model training.</field>
    </record>

    <!-- Data chunks -->
    <record id="chunk_imdb_train_0" model="dataset.data_chunk">
        <field name="dataset_id" ref="dataset_imdb"/>
        <field name="metadata" eval="{'split': 'train', 'shard': '0001'}"/>
        <field name="size">12582912</field>
        <field name="state">checked</field>
        <field name="description">IMDB train split, shard 0001.</field>
    </record>

    <record id="chunk_imdb_train_1" model="dataset.data_chunk">
        <field name="dataset_id" ref="dataset_imdb"/>
        <field name="metadata" eval="{'split': 'train', 'shard': '0002'}"/>
        <field name="size">12582912</field>
        <field name="state">checked</field>
    </record>

    <record id="chunk_imdb_test_0" model="dataset.data_chunk">
        <field name="dataset_id" ref="dataset_imdb"/>
        <field name="metadata" eval="{'split': 'test', 'shard': '0001'}"/>
        <field name="size">10485760</field>
        <field name="state">exists</field>
    </record>

    <record id="chunk_squad_train" model="dataset.data_chunk">
        <field name="dataset_id" ref="dataset_squad"/>
        <field name="metadata" eval="{'split': 'train'}"/>
        <field name="size">42991616</field>
        <field name="state">exists</field>
    </record>

    <record id="chunk_squad_dev" model="dataset.data_chunk">
        <field name="dataset_id" ref="dataset_squad"/>
        <field name="metadata" eval="{'split': 'dev'}"/>
        <field name="size">4194304</field>
        <field name="state">checked</field>
    </record>

    <record id="chunk_cifar10_train_0" model="dataset.data_chunk">
        <field name="dataset_id" ref="dataset_cifar10"/>
        <field name="metadata" eval="{'split': 'train', 'shard': '0001'}"/>
        <field name="size">52428800</field>
        <field name="state">checked</field>
    </record>

    <record id="chunk_cifar10_test_0" model="dataset.data_chunk">
        <field name="dataset_id" ref="dataset_cifar10"/>
        <field name="metadata" eval="{'split': 'test', 'shard': '0001'}"/>
        <field name="size">10485760</field>
        <field name="state">exists</field>
    </record>

    <record id="chunk_titanic" model="dataset.data_chunk">
        <field name="dataset_id" ref="dataset_titanic"/>
        <field name="metadata" eval="{}"/>
        <field name="size">61194</field>
        <field name="state">checked</field>
        <field name="description">Single CSV with all passengers.</field>
    </record>

    <record id="chunk_support_en" model="dataset.data_chunk">
        <field name="dataset_id" ref="dataset_internal_support"/>
        <field name="metadata" eval="{'lang': 'en', 'month': '2026-04'}"/>
        <field name="size">0</field>
        <field name="state">missing</field>
    </record>

    <record id="chunk_support_fr" model="dataset.data_chunk">
        <field name="dataset_id" ref="dataset_internal_support"/>
        <field name="metadata" eval="{'lang': 'fr', 'month': '2026-04'}"/>
        <field name="size">0</field>
        <field name="state">missing</field>
    </record>

    <!--
        HKEX market data: a manifest declares the expected number of
        trading-day chunks for stock_quote; the linkage from manifest to
        its source dataset (trade_calendar) lives in the dataset_dataframe
        addon and is wired up in that addon's demo file.
    -->
    <record id="source_hkex" model="dataset.source">
        <field name="name">HKEX</field>
        <field name="code">hkex</field>
        <field name="url">https://www.hkex.com.hk</field>
        <field name="description">Hong Kong Exchanges and Clearing — listed equities and market data.</field>
    </record>

    <record id="package_markets" model="dataset.package">
        <field name="name">Markets</field>
        <field name="code">markets</field>
        <field name="description">Financial market data: calendars, quotes, fundamentals.</field>
    </record>

    <record id="dataset_hkex_calendar" model="dataset">
        <field name="name">HKEX Trade Calendar</field>
        <field name="code">trade_calendar</field>
        <field name="source_id" ref="source_hkex"/>
        <field name="package_id" ref="package_markets"/>
        <field name="chunk_type">csv</field>
        <field name="key_fields" eval="['year']"/>
        <field name="description">Annual list of HKEX trading days. Authoritative source of "expected chunks" for daily-partitioned datasets like stock_quote.</field>
    </record>

    <record id="manifest_hkex_quote_2026" model="dataset.manifest">
        <field name="name">hkex-quote-2026</field>
        <field name="type">dataset</field>
        <!-- Truncated sample; the full 247-day list is auto-derived from
             trade_calendar when dataset_dataframe is installed. total_chunks
             is computed as len(values). -->
        <field name="values" eval="[
            {'date': '2026-01-02'},
            {'date': '2026-01-05'},
            {'date': '2026-01-06'},
        ]"/>
        <field name="description">Expected daily quote chunks for HKEX in 2026, governed by the trade_calendar dataset (~247 trading days/year).</field>
    </record>

    <record id="dataset_hkex_quote" model="dataset">
        <field name="name">HKEX Stock Quote</field>
        <field name="code">stock_quote</field>
        <field name="source_id" ref="source_hkex"/>
        <field name="package_id" ref="package_markets"/>
        <field name="manifest_id" ref="manifest_hkex_quote_2026"/>
        <field name="chunk_type">parquet</field>
        <field name="key_fields" eval="['date']"/>
        <field name="description">Daily OHLCV snapshot for all HKEX-listed stocks; one chunk per trading day. Expected count is governed by trade_calendar.</field>
    </record>

    <record id="chunk_hkex_calendar_2025" model="dataset.data_chunk">
        <field name="dataset_id" ref="dataset_hkex_calendar"/>
        <field name="metadata" eval="{'year': '2025'}"/>
        <field name="size">8192</field>
        <field name="state">checked</field>
        <field name="description">2025 HKEX trading-day list.</field>
    </record>

    <record id="chunk_hkex_calendar_2026" model="dataset.data_chunk">
        <field name="dataset_id" ref="dataset_hkex_calendar"/>
        <field name="metadata" eval="{'year': '2026'}"/>
        <field name="size">8192</field>
        <field name="state">checked</field>
        <field name="description">2026 HKEX trading-day list.</field>
    </record>

    <record id="chunk_hkex_quote_2026_01_02" model="dataset.data_chunk">
        <field name="dataset_id" ref="dataset_hkex_quote"/>
        <field name="metadata" eval="{'date': '2026-01-02'}"/>
        <field name="size">62914560</field>
        <field name="state">checked</field>
    </record>

    <record id="chunk_hkex_quote_2026_01_05" model="dataset.data_chunk">
        <field name="dataset_id" ref="dataset_hkex_quote"/>
        <field name="metadata" eval="{'date': '2026-01-05'}"/>
        <field name="size">61865984</field>
        <field name="state">checked</field>
    </record>

    <record id="chunk_hkex_quote_2026_05_14" model="dataset.data_chunk">
        <field name="dataset_id" ref="dataset_hkex_quote"/>
        <field name="metadata" eval="{'date': '2026-05-14'}"/>
        <field name="size">63438848</field>
        <field name="state">exists</field>
    </record>

    <record id="chunk_hkex_quote_2026_05_15" model="dataset.data_chunk">
        <field name="dataset_id" ref="dataset_hkex_quote"/>
        <field name="metadata" eval="{'date': '2026-05-15'}"/>
        <field name="size">0</field>
        <field name="state">missing</field>
        <field name="description">Today's quote — listed in catalog by trade_calendar but not yet ingested.</field>
    </record>

    <!--
        CDE guidelines: a regulatory document corpus where every chunk is a
        standalone PDF identified by (publish_date, rule_name, doc_serial).

        Keys look like:
            cde/guidelines/2024-08-15/biosimilar_clinical/2024-127H.pdf

        This is intentionally NOT a Hive-style partition layout. A pattern like
        `dt=2026-01-01/region=us/data.csv` bundles many records under a
        column-equals-value partition — fine for a row-oriented CSV/Parquet
        scan, but meaningless when the chunk *is* the document. Here each PDF
        carries its own (date, rule, serial) tuple, the metadata is positional
        in the path, and the leaf filename is the document itself, not a
        partition file.
    -->
    <record id="source_cde" model="dataset.source">
        <field name="name">CDE</field>
        <field name="code">cde</field>
        <field name="url">https://www.cde.org.cn</field>
        <field name="description">Center for Drug Evaluation — published drug review technical guidelines.</field>
    </record>

    <record id="package_regulatory" model="dataset.package">
        <field name="name">Regulatory</field>
        <field name="code">regulatory</field>
        <field name="description">Regulatory and compliance document corpora.</field>
    </record>

    <record id="package_regulatory_guidelines" model="dataset.package">
        <field name="name">Guidelines</field>
        <field name="code">guidelines</field>
        <field name="parent_id" ref="package_regulatory"/>
    </record>

    <record id="dataset_cde_guidelines" model="dataset">
        <field name="name">CDE Drug Review Guidelines</field>
        <field name="code">guidelines</field>
        <field name="source_id" ref="source_cde"/>
        <field name="package_id" ref="package_regulatory_guidelines"/>
        <field name="chunk_type">pdf</field>
        <field name="key_fields" eval="['publish_date', 'rule_name', 'doc_serial']"/>
        <field name="description">Published technical guidelines for drug evaluation. Each chunk is one official PDF identified by (publish_date, rule_name, doc_serial).</field>
    </record>

    <record id="chunk_cde_biosimilar_clinical" model="dataset.data_chunk">
        <field name="dataset_id" ref="dataset_cde_guidelines"/>
        <field name="metadata" eval="{'publish_date': '2024-08-15', 'rule_name': 'biosimilar_clinical', 'doc_serial': '2024-127H'}"/>
        <field name="size">3145728</field>
        <field name="state">checked</field>
        <field name="description">Clinical comparability technical guideline for biosimilars.</field>
    </record>

    <record id="chunk_cde_pediatric_pk" model="dataset.data_chunk">
        <field name="dataset_id" ref="dataset_cde_guidelines"/>
        <field name="metadata" eval="{'publish_date': '2025-03-21', 'rule_name': 'pediatric_pk', 'doc_serial': '2025-045G'}"/>
        <field name="size">2097152</field>
        <field name="state">checked</field>
        <field name="description">Pharmacokinetic study design guideline for pediatric drug development.</field>
    </record>

    <record id="chunk_cde_oncology_rwe" model="dataset.data_chunk">
        <field name="dataset_id" ref="dataset_cde_guidelines"/>
        <field name="metadata" eval="{'publish_date': '2025-11-04', 'rule_name': 'oncology_real_world_evidence', 'doc_serial': '2025-218B'}"/>
        <field name="size">4718592</field>
        <field name="state">exists</field>
        <field name="description">Use of real-world evidence to support oncology drug review.</field>
    </record>

    <record id="chunk_cde_gene_therapy_cmc" model="dataset.data_chunk">
        <field name="dataset_id" ref="dataset_cde_guidelines"/>
        <field name="metadata" eval="{'publish_date': '2026-01-09', 'rule_name': 'gene_therapy_cmc', 'doc_serial': '2026-003A'}"/>
        <field name="size">0</field>
        <field name="state">missing</field>
        <field name="description">CMC requirements for gene therapy products — listed in catalog, file not yet ingested.</field>
    </record>

</odoo>
