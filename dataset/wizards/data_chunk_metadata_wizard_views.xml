<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_data_chunk_metadata_wizard_form" model="ir.ui.view">
        <field name="name">dataset.data_chunk.metadata_wizard.form</field>
        <field name="model">dataset.data_chunk.metadata_wizard</field>
        <field name="arch" type="xml">
            <form string="Edit Metadata">
                <field name="chunk_id" invisible="1"/>
                <group>
                    <field name="metadata_text" nolabel="1"
                           widget="code" options="{'mode': 'json'}"/>
                </group>
                <footer>
                    <button name="action_save" type="object"
                            string="Save" class="btn-primary"/>
                    <button special="cancel" string="Cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
