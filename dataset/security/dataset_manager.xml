<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="module_category_dataset" model="ir.module.category">
        <field name="name">Dataset</field>
        <field name="description">Dataset management</field>
        <field name="sequence">20</field>
    </record>

    <record id="res_groups_privilege_dataset" model="res.groups.privilege">
        <field name="name">Dataset</field>
        <field name="category_id" ref="module_category_dataset"/>
    </record>

    <record id="group_dataset_manager" model="res.groups">
        <field name="name">Manager</field>
        <field name="sequence">20</field>
        <field name="privilege_id" ref="res_groups_privilege_dataset"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>
</odoo>