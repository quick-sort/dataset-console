<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Table Preview Wizard -->
    <record id="view_table_preview_wizard_form" model="ir.ui.view">
        <field name="name">dataset.table_preview_wizard.form</field>
        <field name="model">dataset.table_preview_wizard</field>
        <field name="arch" type="xml">
            <form string="Table Preview">
                <field name="total_pages" invisible="1"/>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <span class="oe_stat_button" title="Total Rows">
                            <field name="total_rows" string="Total Rows" readonly="1"/>
                        </span>
                    </div>
                    <group>
                        <field name="table_html" readonly="1" widget="html" nolabel="1" style="max-height: 400px; overflow: auto;"/>
                    </group>
                </sheet>
                <footer>
                    <div style="display: flex; align-items: center; gap: 8px;">
                        <button string="&#9664; Prev" name="action_prev" type="object" class="btn-secondary"/>
                        <span style="padding: 0 12px; font-weight: bold;"><field name="page_label" readonly="1"/></span>
                        <button string="Next &#9654;" name="action_next" type="object" class="btn-secondary"/>
                        <div class="ml-auto" style="display: flex; align-items: center; gap: 8px;">
                            <field name="page_size" nolabel="1" style="width: 33%;"/>
                            <button string="Close" special="cancel" class="btn-secondary"/>
                        </div>
                    </div>
                </footer>
            </form>
        </field>
    </record>
</odoo>
