<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_data_chunk_form_storage" model="ir.ui.view">
        <field name="name">dataset.data_chunk.form.storage</field>
        <field name="model">dataset.data_chunk</field>
        <field name="inherit_id" ref="dataset.view_data_chunk_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='raw_data']/.." position="after">
                <group>
                    <button name="cleanup_raw_data" type="object"
                            string="Cleanup Raw Data" icon="fa-trash"
                            confirm="Delete the raw data of this chunk from storage?"/>
                </group>
            </xpath>
        </field>
    </record>
</odoo>
