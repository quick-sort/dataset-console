<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_dataset_form_storage" model="ir.ui.view">
        <field name="name">dataset.form.storage</field>
        <field name="model">dataset</field>
        <field name="inherit_id" ref="dataset.view_dataset_form"/>
        <field name="arch" type="xml">
            <field name="manifest_id" position="after">
                <field name="storage_id"/>
            </field>
        </field>
    </record>

    <record id="view_dataset_list_storage" model="ir.ui.view">
        <field name="name">dataset.list.storage</field>
        <field name="model">dataset</field>
        <field name="inherit_id" ref="dataset.view_dataset_list"/>
        <field name="arch" type="xml">
            <field name="manifest_id" position="after">
                <field name="storage_id" optional="hide"/>
            </field>
        </field>
    </record>

    <record id="view_dataset_search_storage" model="ir.ui.view">
        <field name="name">dataset.search.storage</field>
        <field name="model">dataset</field>
        <field name="inherit_id" ref="dataset.view_dataset_search"/>
        <field name="arch" type="xml">
            <field name="manifest_id" position="after">
                <field name="storage_id"/>
            </field>
            <filter name="group_manifest" position="after">
                <filter string="Storage" name="group_storage" domain="[]" context="{'group_by': 'storage_id'}"/>
            </filter>
        </field>
    </record>
</odoo>
