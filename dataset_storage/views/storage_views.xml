<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_storage_form" model="ir.ui.view">
        <field name="name">dataset.storage.form</field>
        <field name="model">dataset.storage</field>
        <field name="arch" type="xml">
            <form string="Storage">
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_test" type="object"
                                class="oe_stat_button" icon="fa-play">
                            <field name="name" string="Test" modifier="readonly"/>
                        </button>
                    </div>
                    <group>
                        <field name="name"/>
                        <field name="backend_type"/>
                        <field name="gzip_chunk_types" widget="json_editor"/>
                    </group>
                    <group>
                        <field name="config" widget="json_editor"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_storage_list" model="ir.ui.view">
        <field name="name">dataset.storage.list</field>
        <field name="model">dataset.storage</field>
        <field name="arch" type="xml">
            <list string="Storages">
                <field name="name"/>
                <field name="backend_type"/>
            </list>
        </field>
    </record>

    <record id="action_storage" model="ir.actions.act_window">
        <field name="name">Storages</field>
        <field name="res_model">dataset.storage</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_storage"
              name="Storages"
              parent="dataset.menu_dataset_settings"
              action="action_storage"
              sequence="15"/>
</odoo>