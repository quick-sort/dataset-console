<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_storage_form" model="ir.ui.view">
        <field name="name">dataset.storage.form</field>
        <field name="model">dataset.storage</field>
        <field name="arch" type="xml">
            <form string="Storage">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="backend_type"/>
                        <field name="is_default"/>
                    </group>
                    <group>
                        <field name="config"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_storage_tree" model="ir.ui.view">
        <field name="name">dataset.storage.tree</field>
        <field name="model">dataset.storage</field>
        <field name="arch" type="xml">
            <tree string="Storages">
                <field name="name"/>
                <field name="backend_type"/>
                <field name="is_default"/>
            </tree>
        </field>
    </record>

    <record id="action_storage" model="ir.actions.act_window">
        <field name="name">Storages</field>
        <field name="res_model">dataset.storage</field>
        <field name="view_mode">tree,form</field>
    </record>

    <menuitem id="menu_storage"
              name="Storages"
              parent="dataset.menu_dataset_root"
              action="action_storage"
              sequence="15"/>
</odoo>